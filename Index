<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Volleyball Team Generator</title>
    <style>
        :root { --primary: #2563eb; --background: #f8fafc; --surface: #ffffff; --text: #0f172a; }
        body { font-family: system-ui, sans-serif; background: var(--background); color: var(--text); padding: 20px; max-width: 800px; margin: 0 auto; transition: all 0.3s ease; padding-top: 40px; }
        .card { background: var(--surface); padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }
        input, select, button { padding: 10px; font-size: 16px; border: 1px solid #cbd5e1; border-radius: 4px; margin-bottom: 10px; width: 100%; box-sizing: border-box;}
        button { background: var(--primary); color: white; border: none; cursor: pointer; font-weight: bold; }
        button:hover { background: #1d4ed8; }
        .btn-danger { background: #ef4444; }
        .btn-outline { background: transparent; color: var(--text); border: 2px solid var(--primary); }
        .hidden { display: none !important; }
        .badge { font-size: 12px; padding: 3px 8px; border-radius: 12px; background: #e2e8f0; }
        .teams-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .team-box { background: var(--surface); border: 2px solid var(--primary); border-radius: 8px; padding: 15px; transition: all 0.3s ease; }
        .admin-link { text-align: center; margin-top: 30px; font-size: 12px; color: #94a3b8; cursor: pointer; }
        #loading { text-align: center; color: var(--primary); font-weight: bold; margin-bottom: 15px; }
        .waiting-list-box { background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0; margin-top: 20px; text-align: left; }
        .waiting-list-box h3 { margin-top: 0; font-size: 18px; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px; }
        .waiting-list { list-style: none; padding: 0; max-height: 250px; overflow-y: auto; margin-bottom: 0; }
        .waiting-item { display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #ffffff; border: 1px solid #e2e8f0; margin-bottom: 5px; border-radius: 4px; }
        .queue-container { background: #e0f2fe; padding: 10px; border-radius: 4px; margin-bottom: 15px; border: 1px solid #bae6fd; }
        .queue-list { list-style: none; padding: 0; margin: 0; }
        .queue-list li { display: flex; justify-content: space-between; background: #fff; padding: 8px; margin-bottom: 5px; border-radius: 4px; border: 1px solid #cbd5e1; }
        .btn-remove { color: #ef4444; font-weight: bold; cursor: pointer; }
        
        /* BRACKET & SCORE STYLES */
        .bracket-card { background: #f0fdf4; border: 2px solid #22c55e; }
        .bracket-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .bracket-controls button { width: auto; padding: 8px 15px; margin: 0; background: #22c55e; }
        .bracket-controls button:hover { background: #16a34a; }
        .bracket-controls h2 { margin: 0; color: #166534; font-size: 24px; }
